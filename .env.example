# === SUPABASE (público - seguro para commit) ===
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# === CLOUDINARY ===
# Cloud Name (público)
CLOUDINARY_CLOUD_NAME=tu-cloud-name

# API Key y Secret (PRIVADOS - configurar en Vercel, NO commitar)
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# Upload Preset (opcional - para unsigned uploads)
CLOUDINARY_UPLOAD_PRESET=tu-upload-preset

# === GEMINI AI (PRIVADO - configurar en Vercel) ===
GEMINI_API_KEY=tu-gemini-api-key
